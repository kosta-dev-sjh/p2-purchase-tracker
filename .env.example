# Example env file for local development only.
# Copy this file to `.env.local` and fill in values there.
# Do not commit real secrets to git.

# Firebase public client config (only when Firebase is actually connected)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Server-side or Functions-only secrets should never use the `VITE_` prefix.
# Keep those in backend-only env files outside the frontend bundle.
